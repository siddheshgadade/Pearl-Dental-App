<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Include the Custom Toolbar -->
    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Scrollable View for better UI adjustment -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analysis Dashboard"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:paddingBottom="10dp" />

            <!-- Bar Chart for Doctor Appointments -->
            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="10dp" />

            <!-- Explanation for Bar Chart -->
            <TextView
                android:id="@+id/barChartDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This chart represents the number of appointments handled by each doctor."
                android:textSize="16sp"
                android:padding="8dp"
                android:gravity="center"
                android:textColor="#555555" />

            <!-- Pie Chart for Payment Status -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="10dp" />

            <!-- Explanation for Pie Chart -->
            <TextView
                android:id="@+id/pieChartDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This chart shows the ratio of completed vs. pending payments."
                android:textSize="16sp"
                android:padding="8dp"
                android:gravity="center"
                android:textColor="#555555" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
