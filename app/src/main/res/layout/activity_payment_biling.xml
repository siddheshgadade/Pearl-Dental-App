<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp"
    android:fitsSystemWindows="true">

  <!-- Toolbar at the top -->
  <include
      android:id="@+id/toolbar"
      layout="@layout/toolbar_layout"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="?attr/colorPrimary"
      android:fitsSystemWindows="true"/>

  <!-- Heading for Payment Request -->
  <TextView
      android:id="@+id/tvPaymentRequestHeading"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="Send Payment Request"
      android:textSize="20sp"
      android:textStyle="bold"
      android:gravity="center"
      android:paddingTop="16dp"
      android:paddingBottom="8dp"
      android:textColor="@android:color/black"/>

  <!-- Input Fields -->
  <EditText
      android:id="@+id/etPatientEmail"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:hint="Enter Patient Email"
      android:padding="12dp"/>

  <EditText
      android:id="@+id/etAmount"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:hint="Enter Amount"
      android:inputType="numberDecimal"
      android:padding="12dp"/>

  <!-- Send Payment Button -->
  <Button
      android:id="@+id/btnSendPaymentRequest"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:backgroundTint="@color/bright_blue"
      android:text="Send Payment Request"
      android:layout_marginTop="10dp"/>

  <!-- Completed Payments Heading -->
  <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="Completed Payments"
      android:textSize="18sp"
      android:textStyle="bold"
      android:paddingTop="20dp"
      android:paddingBottom="8dp"/>

  <!-- RecyclerView for Completed Payments -->
  <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/recyclerViewCompletedPayments"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"/>
</LinearLayout>
