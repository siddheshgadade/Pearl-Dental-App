<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center"
    android:background="@android:color/white"
    android:fitsSystemWindows="true">



    <!-- Clinic Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🦷 Pearl Dental Clinic"
        android:textSize="22sp"
        android:textStyle="bold"
        android:paddingBottom="16dp"
        android:gravity="center"
        android:textColor="@android:color/holo_blue_dark"
        android:layout_gravity="center"/>

    <!-- Payment Receipt Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment Receipt"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="10dp"
        android:gravity="center"
        android:layout_gravity="center"/>

    <!-- Divider Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray"
        android:layout_marginBottom="10dp"/>

    <!-- Receipt Details -->
    <TextView
        android:id="@+id/tvReceiptPatientEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Patient Email: "
        android:textSize="16sp"
        android:paddingTop="4dp"/>

    <TextView
        android:id="@+id/tvReceiptAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Amount: "
        android:textSize="16sp"
        android:paddingTop="4dp"/>

    <TextView
        android:id="@+id/tvReceiptStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: "
        android:textSize="16sp"
        android:paddingTop="4dp"/>

    <TextView
        android:id="@+id/tvReceiptTransactionId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Transaction ID: "
        android:textSize="16sp"
        android:paddingTop="4dp"/>

    <!-- Second Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray"
        android:layout_marginTop="10dp"/>

    <!-- Download Button -->
    <Button
        android:id="@+id/btnDownloadReceipt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📄 Download Receipt"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/light_blue"
        android:layout_gravity="center"/>
</LinearLayout>
